# StoryForge — Environment Variables
# Copy this file:  cp .env.example .env
# Then edit .env with your values. Never commit .env to git.

# ── Auth Option A: API Key (easiest for local dev, NO gcloud needed) ──────────
# Get a free key at: https://aistudio.google.com/apikey
# The google-genai SDK picks this up automatically.
GOOGLE_API_KEY=AIzaSyCnjUViZyXg5T7ytQg8lg7CUuXYe10fkw0

# ── Auth Option B: Google Cloud (for TTS + Firestore + Cloud Run) ─────────────
# Only needed if you want audio generation or story saving.
# Install gcloud: https://cloud.google.com/sdk/docs/install
# Then run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=gdg-hackathon-489602

# ── Image Generation ──────────────────────────────────────────────────────────
# Use Gemini interleaved output for images (mandatory judging criterion)
USE_GEMINI_IMAGES=true
# Use Imagen 3 via Vertex AI (costs money). false = free Pollinations fallback
USE_IMAGEN=true

# ── Audio Generation ──────────────────────────────────────────────────────────
# Requires Google Cloud TTS API + gcloud auth. Set false to skip audio.
USE_NEURAL2_TTS=true

# ── GCP Region ────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_LOCATION=us-central1

# ── Local Dev ─────────────────────────────────────────────────────────────────
ENV=development
PORT=8080
